<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.metamoto.meta_moto">

    <!-- ═══════════════════════════════════════════════════════════
         PERMISSÕES
         ═══════════════════════════════════════════════════════════ -->

    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- GPS automático de km -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- Overlay flutuante (bolinha sobre outros apps) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Serviço em 1° plano (tracking de km) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>

    <!-- Reiniciar serviço após reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Notificações locais -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Leitura de notificações — concedida manualmente pelo usuário -->
    <!-- android.permission.BIND_NOTIFICATION_LISTENER_SERVICE é declarada no <service> -->

    <!-- Manter CPU ativo em background para o background engine -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <application
        android:label="Meta Moto"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/LaunchTheme"
        android:usesCleartextTraffic="false">

        <!-- ═══ Tela principal Flutter ═══════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ═══ NotificationListenerService ════════════════════════════════
             Lê notificações de Uber, 99, iFood, Lalamove, InDrive.
             Continua rodando mesmo com a tela bloqueada.
             ════════════════════════════════════════════════════════════════ -->
        <service
            android:name=".RideNotificationService"
            android:label="Meta Moto — Leitor de Corridas"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
            <meta-data
                android:name="android.service.notification.default_filter_types"
                android:value="conversations|alerting"/>
        </service>

        <!-- ═══ OverlayService — flutter_overlay_window ═════════════════════
             Roda o overlayMain() entry-point num FlutterEngine isolado.
             Exibe a bolinha flutuante sobre qualquer app.
             ════════════════════════════════════════════════════════════════ -->
        <service
            android:name="com.example.flutter_overlay_window.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:label="Meta Moto Overlay"/>

        <!-- ═══ Metadados Flutter ════════════════════════════════════════ -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

    </application>
</manifest>
